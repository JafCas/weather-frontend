{
  "name": "jca-weather-frontend",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist-lib/weather-widget.umd.cjs",
  "module": "./dist-lib/weather-widget.js",
  "types": "./dist-lib/weather-widget.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/weather-widget.js",
      "require": "./dist-lib/weather-widget.umd.cjs"
    },
    "./style.css": "./dist-lib/weather-widget.css"
  },
  "files": [
    "dist-lib"
  ],
  "scripts": {
    "dev": "npm run backend-select && vite --host",
    "backend-select": "node scripts/switch-backend.mjs",
    "build": "vue-tsc -b && vite build",
    "build:lib": "vue-tsc -b && LIB_BUILD=true vite build",
    "re-build": "rm -rf node_modules dist && npm install && npm run build",
    "re-build:lib": "rm -rf node_modules dist && npm install && npm run build:lib",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
